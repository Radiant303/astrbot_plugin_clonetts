{
    "appid": {
        "type": "string",
        "description": "火山引擎应用 AppID",
        "default": ""
    },
    "access_token": {
        "type": "string",
        "description": "火山引擎 Access Token",
        "default": ""
    },
    "voice_type": {
        "type": "string",
        "description": "音色 ID（在火山引擎控制台获取）",
        "default": ""
    },
    "speed_ratio": {
        "type": "int",
        "description": "语速，取值范围[-50,100]，100代表2.0倍速，-50代表0.5倍数",
        "default": 0
    },
    "loudness_rate": {
        "type": "int",
        "description": "音量，取值范围[-50,100]，100代表2.0倍音量，-50代表0.5倍音量",
        "default": 0
    },
    "sample_rate":{
        "type":"int",
        "description":"音频采样率",
        "options":[8000,16000,22050,24000,32000,44100,48000],
        "default":24000
    },
    "tts_probability": {
        "type": "int",
        "description": "TTS 回复概率(0-100)",
        "default": 80
    },
    "max_length": {
        "type": "int",
        "description": "TTS 的最大字数，超出使用文字",
        "default": 50
    },
    "min_length": {
        "type": "int",
        "description": "TTS 的最小字数，小于该字数不使用语音",
        "default": 5
    },
    "enable_tts": {
        "type": "bool",
        "description": "启用该插件",
        "default": true
    },
    "enable_llm_tool": {
        "type": "bool",
        "description": "启用 LLM 工具",
        "default": true
    },
    "enable_tts_tool_minmax": {
        "type": "bool",
        "description": "是否让LLM工具受字数限制控制",
        "default": true
    },
    "enable_llm_response": {
        "type": "bool",
        "description": "是否允许LLM发送语音后继续回复",
        "default": false
    },
    "llm_recognition":{
        "description": "用于识别输出语气模型（留空则使用当前会话默认模型）",
        "type": "string",
        "default": "",
        "_special": "select_provider"
    }
}